@page "/encounter"
@using DMScreen.Client.Models
@using DMScreen.Client.Services
@inject WikiService WikiService

<PageTitle>Savaş Alanı</PageTitle>

<style>
    /* Piyonların yuvarlak rozet tasarımı */
    .vtt-token {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: white;
        border: 2px solid white;
        box-shadow: 0 4px 6px rgba(0,0,0,0.4);
        position: absolute;
        cursor: grab;
        user-select: none;
        transition: transform 0.1s; /* Tıklayınca ufak bir animasyon */
    }
    .vtt-token:active {
        cursor: grabbing;
        transform: translate(-50%, -50%) scale(1.1) !important; /* Tutunca büyüsün */
    }
    
    /* Üzerine gelince (Hover) açılan detay bilgi kutusu */
    .token-tooltip {
        visibility: hidden;
        opacity: 0;
        position: absolute;
        bottom: 55px; /* Piyonun hemen üstünde çıkar */
        left: 50%;
        transform: translateX(-50%);
        background-color: rgba(33, 37, 41, 0.95);
        color: white;
        text-align: center;
        padding: 8px 12px;
        border-radius: 6px;
        white-space: nowrap;
        z-index: 1000;
        transition: opacity 0.2s;
        pointer-events: none; /* Fareyi bozup sürüklemeyi engellemesin diye */
        box-shadow: 0 4px 8px rgba(0,0,0,0.5);
    }
    
    /* Bilgi kutusunun altındaki o ufak aşağı dönük ok */
    .token-tooltip::after {
        content: "";
        position: absolute;
        top: 100%;
        left: 50%;
        margin-left: -6px;
        border-width: 6px;
        border-style: solid;
        border-color: rgba(33, 37, 41, 0.95) transparent transparent transparent;
    }

    /* Piyona fareyle gelince tooltip'i göster */
    .vtt-token:hover .token-tooltip {
        visibility: visible;
        opacity: 1;
    }
</style>

<div class="row" style="height: 85vh;">
    <div class="col-md-3 bg-light p-3 border-end overflow-auto" style="height: 100%;">
        <h4 class="border-bottom pb-2">Kütüphane</h4>
        <p class="text-muted small">Haritaya eklemek için bir canavar seç:</p>
        
        <div class="list-group">
            @foreach (var monster in WikiService.Monsters)
            {
                <button type="button" 
                        class="list-group-item list-group-item-action d-flex align-items-center @(selectedMonster?.Id == monster.Id ? "active" : "")"
                        @onclick="() => SelectMonster(monster)">
                    
                    <div class="rounded-circle text-white d-flex align-items-center justify-content-center me-3 shadow-sm" 
                         style="min-width: 36px; height: 36px; background-color: @GetColorFromName(monster.Name); font-size: 0.85rem; border: 2px solid rgba(255,255,255,0.5);">
                        @GetInitials(monster.Name)
                    </div>

                    <div class="text-start">
                        <strong>@monster.Name</strong> <br/>
                        <small>HP: @monster.MaxHitPoints | AC: @monster.ArmorClass</small>
                    </div>
                </button>
            }
            @if(WikiService.Monsters.Count == 0)
            {
                <div class="alert alert-warning">Wiki'de hiç canavar yok!</div>
            }
        </div>

        @if(selectedMonster != null)
        {
            <button class="btn btn-outline-danger w-100 mt-3" @onclick="ClearSelection">
                <i class="bi bi-x-circle"></i> Seçimi İptal Et
            </button>
        }
    </div>

    <div class="col-md-9 p-0 position-relative" 
         style="height: 100%; background-color: #d1d8e0; border: 2px dashed #a5b1c2; overflow: hidden; cursor: crosshair;" 
         @onclick="MapClicked"
         ondragover="event.preventDefault();"
         @ondrop="HandleDrop">
        
        @if (selectedMonster == null && activeTokens.Count == 0)
        {
            <div class="position-absolute top-50 start-50 translate-middle text-muted text-center">
                <h3>Oyun Masası</h3>
                <p>Sol taraftan bir canavar seç ve buraya tıklayarak yerleştir.</p>
            </div>
        }

        @foreach (var token in activeTokens)
        {
            <div class="vtt-token" 
                 style="left: @(token.X)px; top: @(token.Y)px; transform: translate(-50%, -50%); background-color: @GetColorFromName(token.Name);"
                 draggable="true"
                 @ondragstart="() => StartDrag(token)"
                 @oncontextmenu="() => DeleteToken(token)"
                 @oncontextmenu:preventDefault="true"
                 @onclick:stopPropagation="true">
                
                @GetInitials(token.Name)

                <div class="token-tooltip">
                    <strong>@token.Name</strong><br/>
                    <span class="badge bg-danger mt-1" style="font-size: 0.9rem;">HP: @token.CurrentHP / @token.MaxHP</span>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private Monster? selectedMonster;
    private List<Token> activeTokens = new List<Token>();
    private Token? draggedToken;

    protected override async Task OnInitializedAsync()
    {
        await WikiService.LoadDataAsync();
    }

    private void SelectMonster(Monster monster) => selectedMonster = monster;
    private void ClearSelection() => selectedMonster = null;

    private void MapClicked(Microsoft.AspNetCore.Components.Web.MouseEventArgs e)
    {
        if (selectedMonster != null)
        {
            activeTokens.Add(new Token
            {
                Name = selectedMonster.Name,
                MaxHP = selectedMonster.MaxHitPoints,
                CurrentHP = selectedMonster.MaxHitPoints,
                X = e.OffsetX, 
                Y = e.OffsetY  
            });
        }
    }

    private void StartDrag(Token token) => draggedToken = token;

    private void HandleDrop(Microsoft.AspNetCore.Components.Web.DragEventArgs e)
    {
        if (draggedToken != null)
        {
            draggedToken.X = e.OffsetX;
            draggedToken.Y = e.OffsetY;
            draggedToken = null; 
        }
    }

    private void DeleteToken(Token token) => activeTokens.Remove(token);

    // --- YARDIMCI METOTLAR (Görsellik İçin) ---

    // Canavar isminden baş harf üretme (Örn: "Sinsi Goblin" -> "SG", "Ork" -> "OR")
    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
        return (parts[0].Substring(0, 1) + parts[1].Substring(0, 1)).ToUpper();
    }

    // Canavar ismine göre sabit ve rastgele bir renk üretme
    private string GetColorFromName(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "#6c757d"; // Gri
        int hash = 0;
        foreach (char c in name) hash = c + ((hash << 5) - hash);
        
        // Çok açık veya çok cırtlak olmaması için renk aralığını dengeliyoruz
        var r = Math.Abs((hash & 0xFF0000) >> 16) % 150 + 50;
        var g = Math.Abs((hash & 0x00FF00) >> 8) % 150 + 50;
        var b = Math.Abs(hash & 0x0000FF) % 150 + 50;
        
        return $"#{r:X2}{g:X2}{b:X2}";
    }
}